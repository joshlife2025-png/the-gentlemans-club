datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  password    String
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Video {
  id          Int      @id @default(autoincrement())
  title       String
  url         String
  isPremium   Boolean  @default(true)
  createdAt   DateTime @default(now())
}
